# ── Model providers ───────────────────────────────────────────────
# OpenAI-compatible endpoint (VNG AI Platform) cho Gemma/Qwen
AI_PLATFORM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
AI_PLATFORM_API_KEY=

# Anthropic (Claude) — premium/fallback path, tuỳ chọn
ANTHROPIC_API_KEY=

# ── Model routing (id model thật điền theo catalog provider) ──────
MODEL_QA=google/gemma-4-31b-it
MODEL_RESEARCH=qwen/qwen-2.5-72b-instruct
MODEL_SYNTHESIS=google/gemma-4-31b-it
MODEL_CRITIC=qwen/qwen-2.5-72b-instruct
MODEL_PREMIUM=claude-sonnet-4-6
MODEL_FALLBACK=google/gemma-4-31b-it

# ── Telegram delivery / Q&A / approval ────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MAX_CHARS_PER_MESSAGE=3900

# ── Workspace & memory ────────────────────────────────────────────
# Tự detect từ vị trí CLAUDE.md nếu để trống
WORKSPACE_PATH=
GITHUB_REPO=
GITHUB_BRANCH=main
GITHUB_TOKEN=

# ── Timeout (giây) — n8n > task > supervisor > agent > model ──────
RUN_TIMEOUT_QA_SECONDS=30
RUN_TIMEOUT_WEEKLY_SECONDS=480
RUN_TIMEOUT_MONTHLY_SECONDS=720
AGENT_TIMEOUT_SECONDS=120
MODEL_TIMEOUT_SECONDS=60

# ── Evidence / Telegram performance optimizer ─────────────────────
EVIDENCE_RSS_TIMEOUT_SECONDS=8
EVIDENCE_WEB_TIMEOUT_SECONDS=10
EVIDENCE_SOCIAL_TIMEOUT_SECONDS=5
EVIDENCE_FETCH_MAX_WORKERS=6
EVIDENCE_INTERACTIVE_MAX_TARGETS=6
EVIDENCE_CACHE_TTL_SECONDS=3600
SOCIAL_NEGATIVE_CACHE_TTL_SECONDS=21600
QA_CURRENT_RESEARCH_CACHE_TTL_SECONDS=21600
MAX_LIVE_RESEARCH_WORKERS=2

# ── Retry / JSON repair ───────────────────────────────────────────
MODEL_RETRY_LIMIT=2
MODEL_JSON_REPAIR_LIMIT=1

# ── Budget agent / token ──────────────────────────────────────────
MAX_AGENTS_WEEKLY=5
MAX_AGENTS_QA_ESCALATED=3
MAX_INPUT_TOKENS_WORKER=80000
MAX_OUTPUT_TOKENS_WORKER=4000
MAX_OUTPUT_TOKENS_SYNTHESIS=6000

# ── Quality gate ──────────────────────────────────────────────────
QUALITY_MIN_SCORE_PUBLISH=0.80
QUALITY_MIN_SCORE_APPROVAL=0.65

# ── Freshness threshold (ngày) ────────────────────────────────────
TIER1_FRESHNESS_DAYS=7
TIER2_FRESHNESS_DAYS=7
TIER3_FRESHNESS_DAYS=30
MARKET_TRENDS_FRESHNESS_DAYS=90
GPU_PRICING_FRESHNESS_DAYS=14

# ── Memory auto-write ─────────────────────────────────────────────
MEMORY_AUTO_WRITE_ENABLED=false
MEMORY_AUTO_WRITE_MIN_CONFIDENCE=high
MEMORY_AUTO_WRITE_MIN_QUALITY=0.85

# Battlecard auto-write: true → ghi thẳng memory/battlecards/; false → memory/_proposed/ chờ duyệt
BATTLECARD_AUTO_WRITE=false

# ── Runtime ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
PORT=8080
APP_BUILD_IMAGE=
APP_BUILD_TAG=
APP_BUILD_SHA=
APP_BUILD_TIME=

# ── Internal scheduler (replaces external cron control plane) ─────
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Ho_Chi_Minh
SCHEDULER_TRIGGER_TOKEN=
CRON_DAILY_INTELLIGENCE=0 15 * * *
CRON_WEEKLY_DIGEST=0 15 * * fri
CRON_MONTHLY_BRIEF=0 15 1 * *
CRON_COMPETITOR_MONITOR=0 6 * * *
CRON_MEMORY_MAINTENANCE=0 10 * * sun
TELEGRAM_OWNER_CHAT_ID=

# ── Social scrape (Facebook/LinkedIn) — parked: login wall blocks static fetch
ENABLE_SOCIAL_SCRAPE=false

# ── Google News link resolution ────────────────────────────────────
GOOGLE_NEWS_RESOLVE_LINKS=true
GOOGLE_NEWS_RESOLVE_MAX=10
