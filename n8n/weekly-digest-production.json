{
  "name": "GreenNode — Weekly Digest Production",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "0 2 * * 5" }]
        }
      },
      "id": "bb22cc33-0002-4000-8000-000000000001",
      "name": "Schedule Fri 09:00 ICT",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [240, 300],
      "notes": "Fri 09:00 ICT = 02:00 UTC Friday"
    },
    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst pad = n => String(n).padStart(2,'0');\nconst week = `W${String(Math.ceil(now.getUTCDate()/7)).padStart(2,'0')}`;\nconst dateStr = `${now.getUTCFullYear()}-${pad(now.getUTCMonth()+1)}-${pad(now.getUTCDate())}`;\nconst ts = Date.now().toString(36);\nreturn [{ json: { request_id: `weekly-${dateStr}-${ts}`, week_label: week, triggered_at: now.toISOString() } }];"
      },
      "id": "bb22cc33-0002-4000-8000-000000000002",
      "name": "Generate Request ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.AGENTBASE_BASE_URL }}/tasks/weekly-digest",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"request_id\": \"{{ $json.request_id }}\",\n  \"source\": \"n8n-cron\",\n  \"dry_run\": false,\n  \"notify\": true,\n  \"save_output\": true,\n  \"human_approval_required\": true,\n  \"model_policy\": \"balanced\"\n}",
        "options": { "timeout": 600000 }
      },
      "id": "bb22cc33-0002-4000-8000-000000000003",
      "name": "POST /tasks/weekly-digest",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [680, 300],
      "continueOnFail": true
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "id": "cond-status",
              "leftValue": "={{ $json.status }}",
              "rightValue": "failed",
              "operator": { "type": "string", "operation": "notEquals" }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "bb22cc33-0002-4000-8000-000000000004",
      "name": "Run succeeded?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "id": "cond-quality",
              "leftValue": "={{ $json.quality_passed }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equal" }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "bb22cc33-0002-4000-8000-000000000005",
      "name": "Quality passed?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1120, 200]
    },
    {
      "parameters": {
        "jsCode": "const r = $input.first().json;\nconst score = r.quality_score ? (r.quality_score * 100).toFixed(0) + '%' : 'N/A';\nconst fallbacks = (r.fallbacks_used || []).join(', ') || 'none';\nreturn [{ json: {\n  preview_msg: `📋 *Weekly Digest Preview* — ${new Date().toLocaleDateString('vi-VN', {weekday:'long', year:'numeric', month:'long', day:'numeric'})}\\n\\n✅ Quality: ${score} | Fallbacks: ${fallbacks}\\n📁 Artifact: \\`${r.artifact_path || '-'}\\`\\n\\n👉 Xem file \`final.md\` trong artifact path rồi approve/reject.\\n\\nApprove: /approve_${r.task_id}\\nReject: /reject_${r.task_id}`,\n  artifact_path: r.artifact_path,\n  task_id: r.task_id,\n  score: r.quality_score\n}}];"
      },
      "id": "bb22cc33-0002-4000-8000-000000000006",
      "name": "Build Preview Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 160]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $env.TELEGRAM_OWNER_CHAT_ID }}",
        "text": "={{ $json.preview_msg }}",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "id": "bb22cc33-0002-4000-8000-000000000007",
      "name": "Telegram — Send Preview to Owner",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [1560, 160]
    },
    {
      "parameters": {
        "amount": 1,
        "unit": "days",
        "resume": "timeInterval"
      },
      "id": "bb22cc33-0002-4000-8000-000000000008",
      "name": "Wait 24h for Manual Approval",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [1780, 160],
      "notes": "Owner reviews artifact then manually resumes via n8n UI or approval webhook"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.AGENTBASE_BASE_URL }}/tasks/{{ $('Build Preview Message').item.json.task_id }}",
        "options": { "timeout": 15000 }
      },
      "id": "bb22cc33-0002-4000-8000-000000000009",
      "name": "GET Task Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [2000, 160]
    },
    {
      "parameters": {
        "jsCode": "const r = $input.first().json;\nconst prev = $('Build Preview Message').first().json;\nconst score = prev.score ? (prev.score * 100).toFixed(0) + '%' : 'N/A';\nconst date = new Date().toLocaleDateString('vi-VN', {weekday:'long', year:'numeric', month:'long', day:'numeric'});\nreturn [{ json: {\n  publish_msg: `📰 *GreenNode VKS Intelligence — Weekly Digest*\\n${date}\\n\\n_Quality: ${score}_\\n\\nXem báo cáo đầy đủ tại: ${prev.artifact_path || '-'}/final.md`\n}}];"
      },
      "id": "bb22cc33-0002-4000-8000-000000000010",
      "name": "Build Publish Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2220, 160]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $env.TELEGRAM_CHAT_ID }}",
        "text": "={{ $json.publish_msg }}",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "id": "bb22cc33-0002-4000-8000-000000000011",
      "name": "Telegram — Publish to Channel",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [2440, 160]
    },
    {
      "parameters": {
        "jsCode": "const r = $input.first().json;\nconst score = r.quality_score ? (r.quality_score * 100).toFixed(0) + '%' : 'N/A';\nconst issues = (r.warnings || []).slice(0, 5).join('\\n• ');\nreturn [{ json: {\n  msg: `🚨 *Weekly Digest — Quality Failed*\\n\\nScore: ${score}\\nStatus: ${r.status}\\n\\n❌ Issues:\\n• ${issues || 'Xem log n8n'}\\n\\nArtifact: ${r.artifact_path || '-'}`\n}}];"
      },
      "id": "bb22cc33-0002-4000-8000-000000000012",
      "name": "Build Quality Failed Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 360]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $env.TELEGRAM_OWNER_CHAT_ID }}",
        "text": "={{ $json.msg }}",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "id": "bb22cc33-0002-4000-8000-000000000013",
      "name": "Telegram — Notify Quality Failed",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [1560, 360]
    },
    {
      "parameters": {
        "jsCode": "const r = $input.first().json;\nreturn [{ json: { msg: `❌ *Weekly Digest Run Failed*\\n\\nStatus: ${r.status}\\nWarnings: ${(r.warnings||[]).join(', ')}\\n\\nThời gian: ${new Date().toISOString()}` } }];"
      },
      "id": "bb22cc33-0002-4000-8000-000000000014",
      "name": "Build Run Failed Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 460]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $env.TELEGRAM_OWNER_CHAT_ID }}",
        "text": "={{ $json.msg }}",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "id": "bb22cc33-0002-4000-8000-000000000015",
      "name": "Telegram — Notify Run Failed",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [1340, 460]
    },
    {
      "parameters": {},
      "id": "bb22cc33-0002-4000-8000-000000000016",
      "name": "Error Trigger",
      "type": "n8n-nodes-base.errorTrigger",
      "typeVersion": 1,
      "position": [680, 500]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $env.TELEGRAM_OWNER_CHAT_ID }}",
        "text": "=❌ *Weekly Digest Workflow Error*\\n\\n`{{ $json.message }}`\\n\\n{{ new Date().toISOString() }}",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "id": "bb22cc33-0002-4000-8000-000000000017",
      "name": "Telegram — Workflow Error",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [900, 500]
    }
  ],
  "connections": {
    "Schedule Fri 09:00 ICT": {
      "main": [[{ "node": "Generate Request ID", "type": "main", "index": 0 }]]
    },
    "Generate Request ID": {
      "main": [[{ "node": "POST /tasks/weekly-digest", "type": "main", "index": 0 }]]
    },
    "POST /tasks/weekly-digest": {
      "main": [[{ "node": "Run succeeded?", "type": "main", "index": 0 }]]
    },
    "Run succeeded?": {
      "main": [
        [{ "node": "Quality passed?", "type": "main", "index": 0 }],
        [{ "node": "Build Run Failed Message", "type": "main", "index": 0 }]
      ]
    },
    "Quality passed?": {
      "main": [
        [{ "node": "Build Preview Message", "type": "main", "index": 0 }],
        [{ "node": "Build Quality Failed Message", "type": "main", "index": 0 }]
      ]
    },
    "Build Preview Message": {
      "main": [[{ "node": "Telegram — Send Preview to Owner", "type": "main", "index": 0 }]]
    },
    "Telegram — Send Preview to Owner": {
      "main": [[{ "node": "Wait 24h for Manual Approval", "type": "main", "index": 0 }]]
    },
    "Wait 24h for Manual Approval": {
      "main": [[{ "node": "GET Task Status", "type": "main", "index": 0 }]]
    },
    "GET Task Status": {
      "main": [[{ "node": "Build Publish Message", "type": "main", "index": 0 }]]
    },
    "Build Publish Message": {
      "main": [[{ "node": "Telegram — Publish to Channel", "type": "main", "index": 0 }]]
    },
    "Build Quality Failed Message": {
      "main": [[{ "node": "Telegram — Notify Quality Failed", "type": "main", "index": 0 }]]
    },
    "Build Run Failed Message": {
      "main": [[{ "node": "Telegram — Notify Run Failed", "type": "main", "index": 0 }]]
    },
    "Error Trigger": {
      "main": [[{ "node": "Telegram — Workflow Error", "type": "main", "index": 0 }]]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner"
  },
  "tags": ["greennode", "weekly-digest", "production"],
  "pinData": {}
}
